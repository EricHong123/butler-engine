# ═══════════════════════════════════════════════════════════
#  Butler Engine — Docker 环境配置
#  复制为 .env，修改后启动
# ═══════════════════════════════════════════════════════════

# ── LLM Provider（必填）──
# 可选: deepseek / qwen / kimi / zhipu / doubao / baichuan /
#       minimax / sensenova / hunyuan / stepfun / claude / openai / custom
BUTLER_PROVIDER=deepseek

# ── LLM API Key（根据上面的 provider 填写对应的 key）──
DEEPSEEK_API_KEY=sk-your-api-key-here

# ── 可选: 自定义模型名 ──
# BUTLER_CHAT_MODEL=deepseek-chat

# ── 数据库密码 ──
DB_PASSWORD=butler

# ── JWT Secret（生产环境务必修改）──
BUTLER_JWT_SECRET=change-me-in-production
