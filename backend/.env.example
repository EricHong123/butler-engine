# ═══════════════════════════════════════════════════════════
#  Butler Engine — LLM 供应商配置
#  复制此文件为 .env，取消注释即可启用
# ═══════════════════════════════════════════════════════════

# ── 选择供应商：设为下面任一 preset key ──
BUTLER_PROVIDER=deepseek

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 1: DeepSeek 深度求索 — 中文流畅，性价比最高       │
# │ 获取 Key: https://platform.deepseek.com/api_keys        │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 2: 阿里通义千问 Qwen — 中文理解强，阿里云生态     │
# │ 获取 Key: https://dashscope.console.aliyun.com/apiKey   │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=qwen
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 3: Moonshot Kimi — 128K 超长上下文，文档分析强     │
# │ 获取 Key: https://platform.moonshot.cn/console/api-keys │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=kimi
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 4: 智谱 GLM-4 — 多模态，中文问答优秀               │
# │ 获取 Key: https://open.bigmodel.cn/usercenter/apikeys   │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=zhipu
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 5: 字节豆包 Doubao — 256K 超长上下文，企业级并发    │
# │ 获取 Key: https://console.volcengine.com/ark            │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=doubao
# ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 6: 百川 Baichuan4 — 中文理解与生成均衡              │
# │ 获取 Key: https://platform.baichuan-ai.com/console      │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=baichuan
# BAICHUAN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 7: MiniMax 海螺 — 语音合成强，适合语音回复          │
# │ 获取 Key: https://platform.minimax.chat/user-center     │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=minimax
# MINIMAX_API_KEY=xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 8: 商汤日日新 SenseChat — 多模态，视觉理解强        │
# │ 获取 Key: https://platform.sensenova.cn/console         │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=sensenova
# SENSENOVA_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 9: 腾讯混元 Hunyuan — 微信生态整合，企业微信对接    │
# │ 获取 Key: https://console.cloud.tencent.com/hunyuan     │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=hunyuan
# HUNYUAN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 10: 阶跃星辰 Step — 数学推理强，多模态              │
# │ 获取 Key: https://platform.stepfun.com/api-keys         │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=stepfun
# STEPFUN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 11: Anthropic Claude — 最强推理+工具调用，英文最优  │
# │ 获取 Key: https://console.anthropic.com                 │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 12: OpenAI GPT-4o — 综合能力最强（需海外 Key）       │
# │ 获取 Key: https://platform.openai.com/api-keys          │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────┐
# │ 方案 13: 自定义 — 任意 OpenAI 兼容端点                   │
# └─────────────────────────────────────────────────────────┘
# BUTLER_PROVIDER=custom
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# BUTLER_OPENAI_BASE_URL=https://your-proxy.com/v1
# BUTLER_CHAT_MODEL=your-model-name

# ── 企业微信（生产环境需要）──
# WECHAT_CORP_ID=wx_xxxxx
# WECHAT_TOKEN=your_token
# WECHAT_ENCODING_AES_KEY=your_43_char_base64_key
# WECHAT_AGENT_ID=1000001

# ── 数据库（生产环境需要）──
# DATABASE_URL=postgresql+asyncpg://butler:password@localhost:5432/butler

# ── 安全 ──
# ENCRYPTION_MASTER_KEY=64位十六进制字符串
